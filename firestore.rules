rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email.lower() == "chichine153@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidProduct(data) {
      return data.sku is string && data.sku.size() > 0 &&
             data.name is string && data.name.size() > 0 &&
             (data.stock is int || data.stock is float);
    }

    function isValidOrder(data) {
      return data.trackingCode is string && data.trackingCode.size() > 0 &&
             data.processedAt is string &&
             data.sku is string &&
             data.quantity is int;
    }

    match /inventory/{productId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && (request.resource.data.userId == request.auth.uid || isAdmin());
      allow update, delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /orders/{orderId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && (isAdmin() || request.resource.data.userId == request.auth.uid);
      allow update: if isAdmin();
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /processed_orders/{orderId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid || isAdmin());
      allow write: if isAuthenticated() && (request.resource.data.userId == request.auth.uid || isAdmin());
    }

    match /shipping_labels/{labelId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && (request.resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAdmin();
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /inventory_logs/{logId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && (request.resource.data.userId == request.auth.uid || isAdmin());
    }
    
    match /users/{userId} {
      allow read, write: if request.auth.uid == userId || isAdmin();
    }

    match /profit_configs/{userId} {
      allow read, write: if request.auth.uid == userId || isAdmin();
    }

    match /returns/{returnId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && (request.resource.data.userId == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin();
    }
  }
}
