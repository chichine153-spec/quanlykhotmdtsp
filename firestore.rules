rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields:
    //   - uid: string
    //   - role: string ('admin', 'user')
    //   - email: string
    //   - status: string ('active', 'inactive')
    //   - paymentStatus: string ('none', 'pending', 'completed')
    //   - phone: string
    //   - expiryDate: string (ISO date)
    //   - createdAt: string
    //
    // Collection: payment_history
    // Fields:
    //   - email: string
    //   - amount: number
    //   - package: string
    //   - activatedAt: string
    //   - userId: string
    //
    // Collection: inventory
    // Fields:
    //   - userId: string (owner)
    //   - name: string
    //   - sku: string
    //   - stock: number
    //   - variant: string
    //   - category: string
    //   - image: string
    //   - status: string
    //   - costPrice: number
    //   - sellingPrice: number
    //   - destination: string
    //   - createdAt: string
    //
    // Collection: inventory_logs
    // Fields:
    //   - userId: string (owner)
    //   - sku: string
    //   - productName: string
    //   - variant: string
    //   - change: number
    //   - type: string
    //   - timestamp: timestamp
    //
    // Collection: orders
    // Fields:
    //   - userId: string (owner)
    //   - trackingCode: string
    //   - processedAt: string
    //   - items: list
    //   - totalRevenue: number
    //   - totalCost: number
    //   - packagingFee: number
    //   - destination: string
    //
    // Collection: returns
    // Fields:
    //   - userId: string (owner)
    //   - trackingCode: string
    //   - returnedAt: string
    //   - items: list
    //
    // Collection: profit_configs
    // Document ID: userId
    // Fields:
    //   - packagingCostBottle: number
    //   - packagingCostCup: number
    //   - platformFeePercent: number
    //   - marketingCost: number
    //   - otherCosts: number
    //   - lastUpdated: string
    //
    // Collection: shipping_labels
    // Fields:
    //   - userId: string (owner)
    //   - trackingCode: string
    //   - pdfUrl: string
    //   - uploadDate: string
    //
    // Collection: processed_orders
    // Fields:
    //   - userId: string (owner)
    //   - trackingCode: string
    //   - processedAt: string
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "chichine153@gmail.com" ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isDocOwner() {
      return isAuthenticated() && (
        isAdmin() ||
        (resource != null && resource.data.userId == request.auth.uid)
      );
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUser(data) {
      return hasOnlyAllowedFields(['role', 'email', 'status', 'expiryDate', 'uid', 'createdAt', 'phone', 'paymentStatus']) &&
             data.role in ['admin', 'user'] &&
             data.status in ['active', 'inactive'] &&
             (!('paymentStatus' in data) || data.paymentStatus in ['none', 'pending', 'completed']) &&
             data.email is string;
    }

    function isValidPayment(data) {
      return hasRequiredFields(['email', 'amount', 'package', 'activatedAt', 'userId']) &&
             data.email is string &&
             data.amount is number &&
             data.userId is string;
    }

    function isValidProduct(data) {
      return isAdmin() || (
        hasRequiredFields(['name', 'sku', 'stock', 'userId']) &&
        data.name is string && data.name.size() > 0 && data.name.size() < 500 &&
        data.sku is string && data.sku.size() > 0 && data.sku.size() < 200 &&
        data.stock is number &&
        data.userId == request.auth.uid
      );
    }

    function isValidLog(data) {
      return isAdmin() || (
        hasRequiredFields(['sku', 'productName', 'change', 'type', 'userId', 'timestamp']) &&
        data.userId == request.auth.uid
      );
    }

    function isValidOrder(data) {
      return isAdmin() || (
        hasRequiredFields(['trackingCode', 'items', 'userId']) &&
        data.userId == request.auth.uid
      );
    }

    function isValidReturn(data) {
      return isAdmin() || (
        hasRequiredFields(['trackingCode', 'items', 'userId']) &&
        data.userId == request.auth.uid
      );
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create: if isAuthenticated() && request.auth.uid == userId && 
                    (
                      (request.resource.data.role == 'user' && request.resource.data.status == 'inactive') ||
                      (request.auth.token.email == "chichine153@gmail.com" && request.resource.data.role == 'admin' && request.resource.data.status == 'active')
                    );
      allow update: if isAdmin() || (isOwner(userId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['phone', 'paymentStatus']));
      allow delete: if isAdmin();
    }

    match /payment_history/{paymentId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /inventory/{productId} {
      allow read: if isDocOwner();
      allow list: if isAuthenticated(); 
      allow create: if isAuthenticated() && isValidProduct(request.resource.data);
      allow update: if isDocOwner() && isValidProduct(request.resource.data);
      allow delete: if isDocOwner();
    }

    match /inventory_logs/{logId} {
      allow read: if isDocOwner();
      allow list: if isAuthenticated();
      allow create: if isAuthenticated() && isValidLog(request.resource.data);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isDocOwner();
      allow list: if isAuthenticated();
      allow create: if isAuthenticated() && isValidOrder(request.resource.data);
      allow update: if isDocOwner();
      allow delete: if isDocOwner();
    }

    match /returns/{returnId} {
      allow read: if isDocOwner();
      allow list: if isAuthenticated();
      allow create: if isAuthenticated() && isValidReturn(request.resource.data);
      allow update: if isDocOwner();
      allow delete: if isDocOwner();
    }

    match /profit_configs/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();
    }

    match /shipping_labels/{labelId} {
      allow read: if isDocOwner();
      allow list: if isAuthenticated();
      allow create: if isAuthenticated() && (request.resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isDocOwner();
      allow delete: if isDocOwner();
    }

    match /processed_orders/{orderId} {
      allow read: if isDocOwner();
      allow list: if isAuthenticated();
      allow create: if isAuthenticated() && (request.resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isDocOwner();
      allow delete: if isDocOwner();
    }
  }
}
