{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user profile information, roles, and subscription status.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "role": { "type": "string", "enum": ["super_admin", "admin", "user"] },
        "planType": { "type": "string", "enum": ["free", "pro", "enterprise"] },
        "dailyOrderCount": { "type": "integer" },
        "orderLimit": { "type": "integer" },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "paymentStatus": { "type": "string", "enum": ["none", "pending", "completed"] },
        "geminiApiKey": { "type": "string" },
        "failoverEnabled": { "type": "boolean" },
        "expiryDate": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "status", "paymentStatus", "createdAt"]
    },
    "PaymentHistory": {
      "title": "Payment History",
      "description": "Stores logs of subscription activations and payments.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "amount": { "type": "number" },
        "package": { "type": "string" },
        "activatedAt": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" }
      },
      "required": ["email", "amount", "package", "activatedAt", "userId"]
    },
    "Product": {
      "title": "Product",
      "description": "An item in the warehouse inventory.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The ID of the user who owns this product." },
        "sku": { "type": "string", "description": "Internal SKU code." },
        "name": { "type": "string", "description": "Product name." },
        "stock": { "type": "integer", "description": "Current stock quantity." },
        "variant": { "type": "string", "description": "Product variant (e.g., color, size)." },
        "category": { "type": "string", "description": "Product category." },
        "image": { "type": "string", "format": "uri", "description": "URL to the product image." },
        "status": { "type": "string", "description": "Stock status (e.g., in_stock, low_stock)." },
        "costPrice": { "type": "number", "description": "Cost price of the product." },
        "sellingPrice": { "type": "number", "description": "Selling price of the product." },
        "destination": { "type": "string", "description": "Warehouse destination (e.g., Hà Nội, Hồ Chí Minh)." },
        "inTransit": { "type": "integer", "description": "Quantity currently in transit from factory." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the product was created." }
      },
      "required": ["userId", "sku", "name", "stock"]
    },
    "Order": {
      "title": "Order",
      "description": "A processed order record.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The ID of the user who owns this order." },
        "trackingCode": { "type": "string", "description": "Shopee tracking code." },
        "processedAt": { "type": "string", "format": "date-time", "description": "When the order was processed." },
        "items": { "type": "array", "items": { "type": "object" }, "description": "List of items in the order." },
        "totalRevenue": { "type": "number", "description": "Total revenue from the order." },
        "totalCost": { "type": "number", "description": "Total cost of items in the order." },
        "packagingFee": { "type": "number", "description": "Packaging fee for the order." },
        "destination": { "type": "string", "description": "Shipping destination." }
      },
      "required": ["userId", "trackingCode", "processedAt", "items"]
    },
    "Return": {
      "title": "Return",
      "description": "A returned order record.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The ID of the user who owns this return." },
        "trackingCode": { "type": "string", "description": "Shopee tracking code." },
        "returnedAt": { "type": "string", "format": "date-time", "description": "When the return was processed." },
        "items": { "type": "array", "items": { "type": "object" }, "description": "List of items returned." }
      },
      "required": ["userId", "trackingCode", "returnedAt", "items"]
    },
    "InventoryLog": {
      "title": "InventoryLog",
      "description": "A record of stock changes.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The ID of the user who owns this log." },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the change occurred." },
        "sku": { "type": "string", "description": "SKU of the product." },
        "productName": { "type": "string", "description": "Name of the product." },
        "variant": { "type": "string", "description": "Variant of the product." },
        "change": { "type": "integer", "description": "Quantity changed." },
        "type": { "type": "string", "description": "Type of change (e.g., deduction, addition)." }
      },
      "required": ["userId", "timestamp", "sku", "productName", "change", "type"]
    },
    "ProfitConfig": {
      "title": "ProfitConfig",
      "description": "Configuration for profit calculation.",
      "type": "object",
      "properties": {
        "packagingCostBottle": { "type": "number", "description": "Cost of packaging for bottles." },
        "packagingCostCup": { "type": "number", "description": "Cost of packaging for cups." },
        "platformFeePercent": { "type": "number", "description": "Shopee platform fee percentage." },
        "marketingCost": { "type": "number", "description": "Marketing costs." },
        "otherCosts": { "type": "number", "description": "Other miscellaneous costs." },
        "lastUpdated": { "type": "string", "format": "date-time", "description": "The timestamp of the last update." }
      },
      "required": ["packagingCostBottle", "packagingCostCup", "platformFeePercent", "marketingCost", "otherCosts", "lastUpdated"]
    },
    "InTransitLog": {
      "title": "InTransitLog",
      "description": "A record of goods ordered from factory but not yet in stock.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "sku": { "type": "string" },
        "variant": { "type": "string" },
        "quantity": { "type": "integer" },
        "expectedArrival": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["in_transit", "completed"] },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "productId", "productName", "sku", "quantity", "expectedArrival", "status", "timestamp"]
    },
    "UsageRecord": {
      "title": "Usage Record",
      "description": "Tracks daily order counts for limit enforcement.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "date": { "type": "string", "description": "YYYY-MM-DD" },
        "count": { "type": "integer" }
      },
      "required": ["userId", "date", "count"]
    },
    "GlobalConfig": {
      "title": "Global Settings",
      "description": "System-wide configurations managed by Super Admin.",
      "type": "object",
      "properties": {
        "fallbackGeminiApiKey": { "type": "string" },
        "defaultSalesVelocity": { "type": "number" },
        "defaultFloorFee": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "updatedBy": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile data."
    },
    "/payment_history/{paymentId}": {
      "schema": "PaymentHistory",
      "description": "Payment and activation logs."
    },
    "/inventory/{productId}": {
      "schema": "Product",
      "description": "Warehouse inventory."
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Processed orders."
    },
    "/returns/{returnId}": {
      "schema": "Return",
      "description": "Returned orders."
    },
    "/inventory_logs/{logId}": {
      "schema": "InventoryLog",
      "description": "Stock change logs."
    },
    "/profit_configs/{userId}": {
      "schema": "ProfitConfig",
      "description": "Profit calculation settings per user."
    },
    "/shipping_labels/{labelId}": {
      "schema": "object",
      "description": "Uploaded shipping labels metadata."
    },
    "/processed_orders/{orderId}": {
      "schema": "object",
      "description": "Tracking of processed orders to avoid duplicates."
    },
    "/in_transit_logs/{logId}": {
      "schema": "InTransitLog",
      "description": "Logs for tracking shipments from factory."
    },
    "/usage_records/{recordId}": {
      "schema": "UsageRecord",
      "description": "Daily usage statistics."
    },
    "/global_configs/{configId}": {
      "schema": "GlobalConfig",
      "description": "Shared system settings managed by Admin."
    }
  }
}
